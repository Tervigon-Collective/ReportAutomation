build/
dist/
*.egg
*.egg-info/
.eggs/
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ── Testing / type-checking / linting caches ─────────────────────────────────
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/

# ── Jupyter / IPython ────────────────────────────────────────────────────────
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ── Editors / IDEs ───────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ── OS files ─────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Generated report output / data dumps ─────────────────────────────────────
reports/
*.xlsx
*.csv
*.pdf
*.parquet

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Scratch / one-off diagnostic scripts ─────────────────────────────────────
# Convention: scripts prefixed with `_` are exploratory and not part of the codebase
_check_*.py
_investigate_*.py
_inspect_*.py
_regen_*.py
_diag_*.py
_export_*.py
_verify_*.py
scratch/
sandbox/
