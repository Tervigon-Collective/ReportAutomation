# ── Database ────────────────────────────────────────────────────────────────
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_URI=                             # optional: postgresql://user:pass@host:port/db

# ── Meta / Facebook Ads ─────────────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_AD_ACCOUNT_ID=
META_ACCESS_TOKEN=                  # alias for FACEBOOK_ACCESS_TOKEN

# ── Google Ads ───────────────────────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=       # manager account ID
GOOGLE_ADS_CUSTOMER_ID=             # advertiser account ID
CLIENT_ID=                          # OAuth 2.0 client ID
CLIENT_SECRET=                      # OAuth 2.0 client secret
GRANT_TYPE=refresh_token
REFRESH_TOKEN=

# ── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_STORE=                      # e.g. yourstore.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_PASSWORD=                   # access token / app password
SHOPIFY_API_VERSION=2023-01

# ── Azure / Microsoft Graph (email) ─────────────────────────────────────────
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# ── Firebase ─────────────────────────────────────────────────────────────────
FIREBASE_WEB_API_KEY=
FIREBASE_EMAIL=
FIREBASE_PASSWORD=
FIREBASE_ID_TOKEN=                  # optional; auto-refreshed if email+password set

# ── ClickHouse (Amazon data warehouse) ───────────────────────────────────────
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DATABASE=raw
CLICKHOUSE_SECURE=false
CLICKHOUSE_CONNECT_TIMEOUT=60
CLICKHOUSE_BRAND_ID=20              # brand_id for API + gold queries
DASHBOARD_COMPANY_ID=19             # company_id for General Statistics dashboard

# ── API migration ────────────────────────────────────────────────────────────
USE_API_ONLY=false                  # true = Node-Backend API only (no DB/CH fallbacks)
USE_API_FALLBACK=true               # try v1 APIs before Postgres/ClickHouse
# Amazon WTD/MTD entity sheets (amazon_entity_report.py): CH gold primary
AMAZON_ENTITY_CLICKHOUSE_PRIMARY=true
AMAZON_ENTITY_API_FALLBACK=true
BACKEND_API_BASE_URL=https://backend.seleric.com/api
BACKEND_EMAIL=admin@seleric.ai
BACKEND_PASSWORD=                      # Node-Backend login fallback (not Firebase password)
BACKEND_REMEMBER_ME=true
JWT_ACCESS_TOKEN=                   # paste Node-Backend JWT from dashboard (preferred)
BACKEND_CSRF_TOKEN=                 # optional; for POST requests with CSRF double-submit
BACKEND_REFRESH_TOKEN=              # used to auto-refresh JWT when access token expires
DASHBOARD_COMPANY_ID=19
CLICKHOUSE_BRAND_ID=20
USE_DASHBOARD_STATS=true            # marketing PDF top section: General Statistics (dashboard_stats) vs legacy hourly metrics
PDF_ABBREVIATE_INR=false            # false = full numbers (Rs.1,40,289); true = compact L/K (Rs.1.4L)

# ── Report / Email ────────────────────────────────────────────────────────────
EMAIL_RECIPIENTS=                   # comma-separated list
EMAIL_SENDER=
REPORT_TYPE=long                    # long | short
ENV=production
REPORT_DIR=                         # defaults to /tmp/reports when blank

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_EMAIL=true
ENABLE_PDF=true
USE_FIXED_DATES=false               # set true + dates below for reproducible test runs
FIXED_START_DATE=                   # YYYY-MM-DD
FIXED_END_DATE=                     # YYYY-MM-DD
ROLLUP_START_DATE=                  # override timeframe (optional)
ROLLUP_END_DATE=                    # override timeframe (optional)
REPORT_AS_OF_DATE=                  # freeze WTD/MTD/daily windows (YYYY-MM-DD), e.g. 2026-06-30 for full June MTD

# ── GST ───────────────────────────────────────────────────────────────────────
GST_RATE=0.18                       # 18% India GST

# ── Azure OpenAI (LLM summarization) ──────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=              # e.g. https://your-resource.cognitiveservices.azure.com
AZURE_DEPLOYMENT=                   # e.g. gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ── Misc ──────────────────────────────────────────────────────────────────────
FLASK_SERVER_URL=
