# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.local
.env.*.local
local.settings.json
*.pem
*.key
secrets/

# Keep example env files for onboarding
!.env.example
!.env.sample
!.env.template

# ── Python bytecode / caches ─────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.python_packages/

# ── Virtual environments ─────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/

